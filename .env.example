# PostgreSQL index for portfolio positions and leaderboard statistics.
# Run database/migrations/001_stats_and_positions.sql once, or let the app
# create the same schema lazily on its first database request.
NUXT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/purplex
NUXT_DATABASE_SSL=false

# TxODDS TxLINE World Cup free-tier credentials stay on the Nuxt server.
# Mainnet level 1: 60-second delay. Mainnet level 12: real-time.
# The standard bundle uses SELECTED_LEAGUES=[] and covers World Cup + Int Friendlies.
# Mainnet: https://txline.txodds.com
# Devnet:  https://txline-dev.txodds.com
NUXT_TX_ODDS_API_ORIGIN=https://txline-dev.txodds.com
NUXT_TX_ODDS_API_TOKEN=

# Optional. When omitted, the server starts and caches a guest session automatically.
NUXT_TX_ODDS_GUEST_JWT=

# Public Solana values must match the TxLINE API network above.
NUXT_SOLANA_RPC_URL=https://api.devnet.solana.com
NUXT_PUBLIC_SOLANA_CLUSTER=devnet
NUXT_PUBLIC_TX_ODDS_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
NUXT_PUBLIC_TX_ODDS_TOKEN_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# Single-pool prediction-market contract. Keep development on devnet/localnet.
NUXT_PREDICTION_MARKET_RPC_URL=https://api.devnet.solana.com
NUXT_PUBLIC_PREDICTION_MARKET_CLUSTER=devnet
NUXT_PUBLIC_PREDICTION_MARKET_PROGRAM_ID=FqRv1nR9E2TRQp1LXZmjp98kdWLLYDcLPD5GyUCb8dV4

# Oracle worker. Keep the keypair outside this repository and protect it as a
# deployment secret. The public key must equal the pool's configured oracle.
ORACLE_KEYPAIR_PATH=
ORACLE_RPC_URL=https://api.devnet.solana.com
ORACLE_APP_ORIGIN=http://127.0.0.1:3000
ORACLE_POLL_MS=60000
ORACLE_ODDS_THRESHOLD=0.02
ORACLE_FORCE_UPDATE_MS=600000
ORACLE_STATE_PATH=.data/oracle-state.json
